{
  "name": "pensieve",
  "version": "0.1.0",
  "description": "Local-first pipeline that mines Claude Code session transcripts for daily insight briefs.",
  "private": true,
  "type": "module",
  "bin": {
    "pensieve": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build --config src/dashboard/frontend/vite.config.ts",
    "dev:dashboard": "vite --config src/dashboard/frontend/vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "better-sqlite3": "^11.5.0",
    "chart.js": "^4.5.1",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.14.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.4"
  }
}
